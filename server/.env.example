# ─────────────────────────────────────────────────────────────────────────────
# PLANTILLA DE VARIABLES DE ENTORNO — server/.env.example
#
# Copia este archivo como "server/.env" y rellena los valores reales.
# NUNCA subas el archivo ".env" real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Conexión a MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?appName=<app>
MONGO_URI = "mongodb+srv://TU_USUARIO:TU_CONTRASEÑA@cluster0.xxxxxx.mongodb.net/?appName=NombreApp"
